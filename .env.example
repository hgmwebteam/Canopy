# Supabase (project: wcnfprpvmnroixxetljd, ca-central-1 — client-provided account)
NEXT_PUBLIC_SUPABASE_URL=https://wcnfprpvmnroixxetljd.supabase.co
# Insert-only key (safe to expose). Server routes prefer the service-role key below when present.
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Required for Stripe webhook status updates. Dashboard → Settings → API → service_role. KEEP SECRET.
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — leave empty to run checkout in demo mode
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# GoHighLevel (LeadConnector) — leave empty to skip CRM sync
GHL_API_KEY=
GHL_LOCATION_ID=

# Funnel config
RESERVATION_AMOUNT_CENTS=5000
